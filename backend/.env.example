# ─── Application ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vedarogya
DB_USER=postgres
DB_PASSWORD=changeme
DB_SSL=false

# ─── JWT ────────────────────────────────────────────────────────────────────
# HIPAA: Use strong secrets (min 256-bit) and short expiry for access tokens
JWT_SECRET=replace_with_strong_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_different_strong_secret
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption (HIPAA: encrypt PHI at rest) ────────────────────────────────
ENCRYPTION_KEY=replace_with_32_byte_hex_key

# ─── Rate Limiting ──────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:8081
