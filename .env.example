# ─── Mobile App ───────────────────────────────────────────────────────────────
# Base URL of your running backend (no trailing slash)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1


# ─── Backend ──────────────────────────────────────────────────────────────────

# Node environment: development | production | test
NODE_ENV=development

# Port the NestJS server listens on
PORT=3000

# API route prefix (default: api/v1)
API_PREFIX=api/v1

# Allowed CORS origin — set to your Expo dev URL or production domain
CORS_ORIGIN=http://localhost:8081

# Rate limiting — requests per window
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# 32-byte hex key for encrypting sensitive fields at rest
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=


# ─── Database ─────────────────────────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=5432
DB_NAME=vedarogya
DB_USER=postgres
DB_PASSWORD=

# Set to true in production to require SSL connections
DB_SSL=false


# ─── JWT ──────────────────────────────────────────────────────────────────────

# Access token secret — keep long and random
# Generate: openssl rand -base64 64
JWT_SECRET=

# Access token lifetime (default: 15 minutes)
JWT_EXPIRES_IN=15m

# Refresh token secret — must differ from JWT_SECRET
# Generate: openssl rand -base64 64
JWT_REFRESH_SECRET=

# Refresh token lifetime (default: 7 days)
JWT_REFRESH_EXPIRES_IN=7d
